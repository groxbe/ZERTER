<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VERTER.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:VERTER.Models"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
        x:Class="VERTER.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ZERTER"
        Width="1280" Height="720"
        MinWidth="1280" MinHeight="720"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ShowInTaskbar="{Binding ShowInTaskbar}"
        Icon="avares://ZERTER/Assets/logo.png">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <!-- Header (Custom Title Bar) -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,10" Name="TitleBar">
            <Button Command="{Binding ToggleAboutCommand}" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Image Source="avares://ZERTER/Assets/logo.png" Width="32" Height="32"/>
                    <TextBlock Text="ZERTER" FontSize="28" FontWeight="Bold" Foreground="#BB86FC"/>
                    <TextBlock Text="{Binding AppVersion}" FontSize="14" Foreground="#666666" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                </StackPanel>
            </Button>
            
            <TextBlock Grid.Column="1" Text="Kopyalanan linkler otomatik olarak listeye eklenir ve indirilir" FontSize="12" Foreground="#888888" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0"/>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                    <TextBlock Text="{Binding DownloadPath}" FontSize="11" Foreground="#666666" MaxWidth="200" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <Button Command="{Binding SelectFolderCommand}" Background="Transparent" Padding="5">
                        <TextBlock Text="📁" FontSize="20"/>
                    </Button>
                </StackPanel>
                <!-- Minimize Button -->
                <Button Command="{Binding MinimizeAppCommand}" Background="Transparent" Content="_" FontSize="20" FontWeight="Bold" Foreground="White" Width="40" Height="40" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Main Content (3 Columns) -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *, *" Margin="0,10">
            <!-- Left: Waiting -->
            <StackPanel Grid.Column="0" Margin="5">
                <TextBlock Text="Sıradakiler" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#888888"/>
                <ScrollViewer Height="450">
                    <ItemsControl ItemsSource="{Binding WaitingList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DownloadItem">
                                <Border Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,0,0,5">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveFromWaitingCommand}" 
                                                CommandParameter="{Binding}" Background="Transparent" Padding="2">
                                            <TextBlock Text="✕" FontSize="10" Foreground="Red"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- Center: Downloading -->
            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="İndiriliyor" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#03DAC6"/>
                <ScrollViewer Height="450">
                    <ItemsControl ItemsSource="{Binding DownloadingList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DownloadItem">
                                <Border Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Value="{Binding Progress}" Height="2" Margin="0,4" Foreground="#03DAC6"/>
                                        <TextBlock Text="{Binding Status}" FontSize="9" Foreground="#BB86FC" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- Right: Downloaded -->
            <StackPanel Grid.Column="2" Margin="5">
                <TextBlock Text="İndirilenler" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#BB86FC"/>
                <ScrollViewer Height="450">
                    <ItemsControl ItemsSource="{Binding DownloadedList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DownloadItem">
                                <Border Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,0,0,5">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).TogglePlayCommand}" 
                                                CommandParameter="{Binding}" Background="Transparent" Padding="2">
                                            <TextBlock Text="▶" Foreground="#03DAC6"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>

        <!-- Player Bar -->
        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,10,0,0">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                <Button Grid.Column="0" Command="{Binding TogglePlayCommand}" CommandParameter="{Binding CurrentSong}"
                        Background="Transparent" Padding="0" Margin="0,0,15,0">
                    <TextBlock Text="{Binding PlayPauseIcon}" FontSize="24" Foreground="#BB86FC"/>
                </Button>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,5">
                    <TextBlock Text="{Binding CurrentSong.Title, FallbackValue='Parça Seçilmedi'}" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                    <Slider Value="{Binding PlayerProgress}" Minimum="0" Maximum="100" Height="32" Padding="0" Margin="0,-5,0,0"
                            Foreground="#BB86FC"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="🔊" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <Slider Grid.Column="3" Value="{Binding Volume}" Minimum="0" Maximum="1" Width="100" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- About Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#AA000000" IsVisible="{Binding IsAboutVisible}" ZIndex="100">
            <Border Background="#1E1E1E" CornerRadius="12" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <StackPanel Spacing="20">
                    <Image Source="avares://ZERTER/Assets/logo.png" Width="120" Height="120" HorizontalAlignment="Center"/>
                    <TextBlock Text="ZERTER Hakkında" FontSize="22" FontWeight="Bold" Foreground="#BB86FC" HorizontalAlignment="Center"/>
                    
                    <Separator Background="#333333"/>
                    
                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto" Margin="0,10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Yapımcı:" Foreground="#888888" Margin="0,0,20,10"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeveloperName}" FontWeight="SemiBold"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Sürüm:" Foreground="#888888" Margin="0,0,20,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AppVersion}" FontWeight="SemiBold"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Güncelleme:" Foreground="#888888" Margin="0,0,20,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastUpdateDate}" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Update Section -->
                    <StackPanel Spacing="10">
                        <Button Command="{Binding StartUpdateCommand}" 
                                Background="#03DAC6" Foreground="#121212" FontWeight="Bold" 
                                HorizontalAlignment="Stretch" Padding="15,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <TextBlock Text="{Binding UpdateStatusText}"/>
                            </StackPanel>
                        </Button>
                        <ProgressBar IsVisible="{Binding IsUpdating}" Value="{Binding UpdateProgress}" 
                                     Minimum="0" Maximum="100" Height="10" 
                                     Foreground="#03DAC6" Background="#333333"/>
                    </StackPanel>
                    
                    <TextBlock Text="YouTube'dan MP3 indirmek hiç bu kadar kolay olmamıştı." FontStyle="Italic" FontSize="12" Foreground="#888888" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                    
                    <Button Command="{Binding ToggleAboutCommand}" Content="Kapat" Background="#BB86FC" Foreground="#121212" HorizontalAlignment="Center" Padding="25,8" CornerRadius="20"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
